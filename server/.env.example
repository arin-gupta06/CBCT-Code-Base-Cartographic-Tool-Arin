# Server Configuration
NODE_ENV=production
PORT=5000

# Redis Configuration (Upstash)
# Format for Upstash: rediss://default:PASSWORD@HOST:PORT
# Get from: https://console.upstash.com/
REDIS_URL=rediss://default:your-upstash-token@your-upstash-host:39xxx

# API Configuration
API_TIMEOUT=300000

# CORS Configuration
CORS_ORIGIN=https://your-frontend-domain.vercel.app
